# Stock Grader Environment Variables
# Copy this file to .env.local and fill in as needed

# Finnhub API Key (get free key at https://finnhub.io)
REACT_APP_FINNHUB_API_KEY=your_finnhub_key_here

# Alpha Vantage API Key (get free key at https://www.alphavantage.co)
REACT_APP_ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
